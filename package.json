{
  "name": "godocs",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "predev": "vitest run",
    "dev": "vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:worker": "esbuild src/worker.ts --bundle --format=esm --platform=browser --target=es2022 --conditions=worker,browser --minify --outfile=worker.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "e2e:run": "node --experimental-strip-types scripts/e2e/run.mjs",
    "e2e:validate": "node --experimental-strip-types scripts/e2e/validate.mjs",
    "e2e:validate-llm": "node --experimental-strip-types scripts/e2e/validate-llm.mjs",
    "e2e:cleanup": "node --experimental-strip-types scripts/e2e/cleanup.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/router-plugin": "^1.167.28",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "lucide-react": "^0.575.0",
    "mammoth": "^1.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.8"
  }
