SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# IA Provider (openai ou anthropic)
LLM_PROVIDER="openai"
LLM_API_KEY="your-llm-api-key"
LLM_MODEL="gpt-4.1"
# (Opcional) modelo rápido p/ os turnos de conversa do orquestrador; vazio = usa LLM_MODEL
LLM_MODEL_FAST=""

# TeamGuide — token Bearer de leitura p/ derivar/sincronizar as áreas (api.teamguide.app)
# Lido em src/lib/areas/teamguide.server.ts via process.env.TG_API_TOKEN
TG_API_TOKEN="your-teamguide-api-token"

# OCR Worker (Cloudflare) — extração de texto de PDFs
OCR_WORKER_URL="https://ocr-worker.kaique-rpa.workers.dev/"
OCR_WORKER_TOKEN="your-ocr-worker-token"

# Email (Brevo) — usado pelos e-mails de aprovação/rejeição de projeto
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# Email da cobrança de legados — envio pela Gmail API impersonando uma caixa real
# @gocase.com (Service Account + domain-wide delegation). Reusa a GOOGLE_SA_* abaixo;
# exige DWD habilitada no Workspace para o escopo gmail.send. Override opcional da SA:
# GMAIL_SA_KEY_BASE64 / GMAIL_SA_CLIENT_EMAIL (se não setados, usa a SA do Sheets).
GMAIL_SENDER="rpa_ia@gocase.com"

# Google Service Account — usada para o Google Sheets (e o envio de e-mail via Gmail)
# Base64 da private_key PEM (evita problemas com newlines em env vars)
GOOGLE_SA_KEY_BASE64=""
# Email da Service Account (iss/sub do JWT)
GOOGLE_SA_CLIENT_EMAIL=""

# Google OAuth de USUÁRIO — usado para o UPLOAD ao Drive (a Service Account não
# tem cota de storage, então os arquivos são criados como rpa_ia@gocase.com).
# Gerar uma vez via consentimento offline (refresh token não expira p/ app interno).
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REFRESH_TOKEN=""

# Webhook do Google Chat para notificar novas submissões/análises
GOOGLE_CHAT_WEBHOOK_URL="https://chat.googleapis.com/v1/spaces/.../messages?key=...&token=..."

# Webhook do espaço de SUPORTE/AJUDA do Google Chat (widget de ajuda — spec-docs/SPEC_WIDGET_AJUDA.md)
GOOGLE_CHAT_WEBHOOK_URL_AJUDA="https://chat.googleapis.com/v1/spaces/.../messages?key=...&token=..."

# (Opcional) Override dos IDs padrão do Google Sheets e Drive
# GOOGLE_SHEETS_ID="1xS2zIMu-PGiqxUDOnLNXTqSzUzPlJsQW0_R1Z_4Cxnk"
# GOOGLE_SHEETS_TAB="GoDocs"
# GOOGLE_DRIVE_FOLDER_ID="1e_Fk8EhFsv_W-3A3dRpMIa2Wg1pBHem_"
# (Opcional) Pasta separada p/ os prints do widget de ajuda (default: cai na pasta acima)
# GOOGLE_DRIVE_FOLDER_ID_AJUDA=""

# Header enviado pelo Godeploy com o email do usuário autenticado via Google OAuth
GODEPLOY_USER_HEADER="x-godeploy-user-email"

# (Opcional) Header com o NOME da conta logada, se o edge Godeploy o injetar.
# Quando ausente/vazio, o nome é derivado do local-part do e-mail. O default abaixo
# é o palpite mais provável — ajustar aqui (sem redeploy de código) se o edge usar
# outro nome de header (confirmar inspecionando os headers num deploy).
# GODEPLOY_NAME_HEADER="x-godeploy-user-name"

# Desenvolvimento local: simula o email do usuário autenticado pelo Godeploy
# Remover ou deixar vazio em produção
DEV_USER_EMAIL=""

# Admins (bootstrap) — lista de e-mails separada por vírgula. Fonte canônica de admin,
# fora do código-fonte. isAdmin() (src/lib/auth.functions.ts) = esta lista ∪ tabela
# `admins` (CRUD dinâmico via painel). Em produção, definir como secret no Godeploy.
ADMIN_EMAILS="joao.gabriel@gocase.com,joaovictor.esteves@gocase.com,kaique.breno@gocase.com,luciano.cavalcante@gocase.com,luis.albuquerque@gocase.com"
