SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# IA Provider (openai ou anthropic)
LLM_PROVIDER="openai"
LLM_API_KEY="your-llm-api-key"
LLM_MODEL="gpt-4.1"
# (Opcional) modelo rápido p/ os turnos de conversa do orquestrador; vazio = usa LLM_MODEL
LLM_MODEL_FAST=""

# TeamGuide — token Bearer de leitura p/ derivar/sincronizar as áreas (api.teamguide.app)
# Lido em src/lib/areas/teamguide.server.ts via process.env.TG_API_TOKEN
TG_API_TOKEN="your-teamguide-api-token"

# OCR Worker (Cloudflare) — extração de texto de PDFs
OCR_WORKER_URL="https://ocr-worker.kaique-rpa.workers.dev/"
OCR_WORKER_TOKEN="your-ocr-worker-token"

# Email (Brevo)
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# Webhook do Google Chat para notificar novas submissões
GOOGLE_CHAT_WEBHOOK_URL="https://chat.googleapis.com/v1/spaces/.../messages?key=...&token=..."

# Webhook do n8n para registrar submissões na planilha e Google Drive
N8N_WEBHOOK_URL="https://n8n-study.gogroupgl.com/webhook/godocs_submit"

# Header enviado pelo Godeploy com o email do usuário autenticado via Google OAuth
GODEPLOY_USER_HEADER="x-godeploy-user-email"

# Desenvolvimento local: simula o email do usuário autenticado pelo Godeploy
# Remover ou deixar vazio em produção
DEV_USER_EMAIL=""
