SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# IA Provider (openai ou anthropic)
LLM_PROVIDER="openai"
LLM_API_KEY="your-llm-api-key"
LLM_MODEL="gpt-4.1"

# OCR Worker (Cloudflare) — extração de texto de PDFs
OCR_WORKER_URL="https://ocr-worker.kaique-rpa.workers.dev/"
OCR_WORKER_TOKEN="your-ocr-worker-token"

# Email (Brevo)
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# Header enviado pelo Godeploy com o email do usuário autenticado via Google OAuth
GODEPLOY_USER_HEADER="x-user-email"

# Desenvolvimento local: simula o email do usuário autenticado pelo Godeploy
# Remover ou deixar vazio em produção
DEV_USER_EMAIL=""
